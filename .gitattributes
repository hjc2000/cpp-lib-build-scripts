* 			text=auto eol=input
.txt 		text eol=crlf

# 将 Shell 脚本文件标记为文本，并使用 LF 作为行结束符
*.sh 		text eol=lf

# 将 C、C++ 和 C# 源文件和头文件标记为文本，并使用 LF 作为行结束符
*.[cC] 		text eol=crlf
*.[hH] 		text eol=crlf
*.cpp 		text eol=crlf
*.hpp 		text eol=crlf
*.cxx 		text eol=crlf
*.hxx 		text eol=crlf
*.cc 		text eol=crlf
*.cs		text eol=crlf

# 将 JavaScript 文件及相关前端文件标记为文本，并使用 LF 作为行结束符
*.js 		text eol=crlf
*.jsx 		text eol=crlf
*.tsx 		text eol=crlf
*.html 		text eol=crlf
*.css 		text eol=crlf
*.scss 		text eol=crlf
*.sass 		text eol=crlf
*.json 		text eol=crlf
*.vue 		text eol=crlf
*.svelte 	text eol=crlf
*.xml 		text eol=crlf
*.xaml 		text eol=crlf

# Blazor 相关文件
*.razor text eol=crlf

# Visual Studio 项目文件
